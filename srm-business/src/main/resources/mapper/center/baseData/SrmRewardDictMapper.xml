<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediway.hos.srm.business.center.mapper.baseData.SrmRewardDictMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mediway.hos.srm.business.center.model.entity.baseData.SrmRewardDict">
        <id column="id" property="id" />
        <result column="code" property="code" />
        <result column="name" property="name" />
        <result column="is_valid" property="isValid" />
        <result column="award_type" property="awardType" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, code, name, is_valid, award_type
    </sql>
    <select id="listRewardDict" parameterType="com.mediway.hos.srm.business.center.model.dto.baseData.RewardDictDto" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.RewardDictVo">
        select id as rowId,code,name,is_valid as isValid,award_type  as awardType from ct_srm_reward_dict
    </select>
</mapper>
