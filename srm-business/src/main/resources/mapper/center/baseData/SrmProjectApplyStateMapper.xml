<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediway.hos.srm.business.center.mapper.baseData.SrmProjectApplyStateMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mediway.hos.srm.business.center.model.entity.baseData.SrmProjectApplyState">
        <id column="id" property="id" />
        <result column="code" property="code" />
        <result column="name" property="name" />
        <result column="is_valid" property="isValid" />
        <result column="order_id" property="orderId" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, code, name, is_valid, order_id
    </sql> 
    <select id="getProjectApplyState" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.CombVo">
        select code as id,name from ct_srm_project_apply_state where is_valid=1
    </select>
    <select id="listProjectApplyState" parameterType="com.mediway.hos.srm.business.center.model.dto.baseData.ProjectApplyStateDto" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.ProjectApplyStateVo">
        select id as rowId,code,name,is_valid as isValid from ct_srm_project_apply_state
    </select>
</mapper>
