<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediway.hos.srm.business.center.mapper.baseData.SrmProductModeMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mediway.hos.srm.business.center.model.entity.baseData.SrmProductMode">
        <id column="id" property="id" />
        <result column="code" property="code" />
        <result column="name" property="name" />
        <result column="is_valid" property="isValid" />
        <result column="class_code" property="classCode" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, code, name, is_valid, class_code
    </sql>
    <select id="getProductMode" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.CombVo">
        select code as id,name from ct_srm_product_mode where is_valid=1
    </select>
    <select id="listProductMode" parameterType="com.mediway.hos.srm.business.center.model.dto.baseData.ProductModeDto" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.ProductModeVo">
        select id as rowId,code,name,is_valid as isValid,class_code as classCode   from ct_srm_product_mode
    </select>
</mapper>
