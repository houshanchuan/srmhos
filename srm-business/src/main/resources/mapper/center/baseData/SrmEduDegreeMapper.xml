<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediway.hos.srm.business.center.mapper.baseData.SrmEduDegreeMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mediway.hos.srm.business.center.model.entity.baseData.SrmEduDegree">
        <id column="id" property="id" />
        <result column="code" property="code" />
        <result column="name" property="name" />
        <result column="is_valid" property="isValid" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, code, name, is_valid
    </sql>
    <select id="listEduDegree" parameterType="com.mediway.hos.srm.business.center.model.dto.baseData.EduDegreeDto" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.EduDegreeVo">
        select id as rowId,code,name,is_valid as isValid from ct_srm_edu_degree
    </select>
    <select id="getEduDegree" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.CombVo">
        select code as id,name  from  ct_srm_edu_degree csed where is_valid =1
        <if test="eduDegreeDto.name!=null and eduDegreeDto.name!=''">
            and name LIKE CONCAT('%', #{eduDegreeDto.name}, '%')
        </if>
    </select>

</mapper>
