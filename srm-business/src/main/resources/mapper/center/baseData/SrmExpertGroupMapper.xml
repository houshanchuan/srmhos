<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediway.hos.srm.business.center.mapper.baseData.SrmExpertGroupMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mediway.hos.srm.business.center.model.entity.baseData.SrmExpertGroup">
        <id column="id" property="id" />
        <result column="code" property="code" />
        <result column="name" property="name" />
        <result column="is_valid" property="isValid" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, code, name, is_valid
    </sql>

    <select id="listSrmExpertGroup" parameterType="com.mediway.hos.srm.business.center.model.dto.baseData.ExpertGroupDto" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.ExpertGroupVo">
        select id as rowId,code,name,is_valid as isValid from ct_srm_expert_group
    </select>

    <select id="getExpertGroup" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.CombVo">
        select id,name from ct_srm_expert_group where is_valid=1
    </select>

</mapper>
