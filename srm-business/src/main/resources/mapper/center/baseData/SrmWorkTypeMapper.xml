<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediway.hos.srm.business.center.mapper.baseData.SrmWorkTypeMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mediway.hos.srm.business.center.model.entity.baseData.SrmWorkType">
        <id column="id" property="id" />
        <result column="code" property="code" />
        <result column="name" property="name" />
        <result column="is_valid" property="isValid" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, code, name, is_valid
    </sql>
    <select id="getWorkType" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.CombVo">
        SELECT
            code id, name
        FROM
            ct_srm_work_type
        where is_valid=1
        <if test="workTypeDto.name!=null and workTypeDto.name!=''">
            and name LIKE CONCAT('%', #{workTypeDto.name}, '%')
        </if>
    </select>
    <select id="listWorkType" parameterType="com.mediway.hos.srm.business.center.model.dto.baseData.WorkTypeDto" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.WorkTypeVo">
        select id as rowId,code,name,is_valid as isValid from ct_srm_work_type
    </select>

</mapper>
