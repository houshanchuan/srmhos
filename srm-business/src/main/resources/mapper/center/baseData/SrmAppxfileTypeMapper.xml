<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediway.hos.srm.business.center.mapper.baseData.SrmAppxfileTypeMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mediway.hos.srm.business.center.model.entity.baseData.SrmAppxfileType">
        <id column="id" property="id" />
        <result column="sys_no" property="sysNo" />
        <result column="type" property="type" />
        <result column="code" property="code" />
        <result column="name" property="name" />
        <result column="is_valid" property="isValid" />
        <result column="is_required" property="isRequired" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, sys_no, type, code, name, is_valid, is_required
    </sql>
    <select id="listAppxfileType" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.AppxfileTypeVo">
        SELECT id as rowId,sys_no as sysNo ,type as fileType,code,name ,is_valid as isValid ,is_required as isRequired  FROM cf_srm_appxfile_type csat
     WHERE sys_no=#{sysNo}
    </select>

</mapper>
