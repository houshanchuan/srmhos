<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediway.hos.srm.business.center.mapper.baseData.SrmCommitteeTypeMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mediway.hos.srm.business.center.model.entity.baseData.SrmCommitteeType">
        <id column="id" property="id" />
        <result column="code" property="code" />
        <result column="name" property="name" />
        <result column="is_valid" property="isValid" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, code, name, is_valid
    </sql>
    <select id="listCommitteeType" parameterType="com.mediway.hos.srm.business.center.model.dto.baseData.CommitteeTypeDto" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.CommitteeTypeVo">
        select id as rowId,code,name,is_valid as isValid,level,up_code as upCode
        from ct_srm_committee_info csci
    </select>
    <select id="getCommitteeType">
        select code as id,name from ct_srm_committee_info where is_valid=1
        <if test="committeeTypeDto.level!=null and committeeTypeDto.level!=''">
            and level=#{level}
        </if>
        <if test="committeeTypeDto.upCode!=null and committeeTypeDto.upCode!=''">
            and up_code=#{upCode}
        </if>
    </select>

</mapper>
