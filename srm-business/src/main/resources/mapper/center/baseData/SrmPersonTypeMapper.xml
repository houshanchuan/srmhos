<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediway.hos.srm.business.center.mapper.baseData.SrmPersonTypeMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mediway.hos.srm.business.center.model.entity.baseData.SrmPersonType">
        <id column="id" property="id" />
        <result column="code" property="code" />
        <result column="name" property="name" />
        <result column="is_valid" property="isValid" />
        <result column="is_external" property="isExternal" />
        <result column="is_graduate" property="isGraduate" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, code, name, is_valid, is_external, is_graduate,is_instaff
    </sql>
    <select id="getPersonType" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.CombVo">
        SELECT
             code as id, name
        FROM
            ct_srm_person_type
        where is_valid=1
    </select>
    <select id="listPersonType" parameterType="com.mediway.hos.srm.business.center.model.dto.baseData.PersonTypeDto" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.PersonTypeVo">
        select id as rowId,code,name,is_valid as isValid,is_external as isExternal,is_graduate as isGraduate,is_instaff as isInStaff
        from ct_srm_person_type
    </select>
</mapper>
