<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediway.hos.srm.business.center.mapper.baseData.SrmResearchTypeMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mediway.hos.srm.business.center.model.entity.baseData.SrmResearchType">
        <id column="id" property="id" />
        <result column="code" property="code" />
        <result column="name" property="name" />
        <result column="is_valid" property="isValid" />
        <result column="class_code" property="classCode" />
        <result column="research_type" property="researchType" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, code, name, is_valid, class_code, research_type
    </sql>

    <select id="listResearchType" parameterType="com.mediway.hos.srm.business.center.model.dto.baseData.ResearchTypeDto" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.ResearchTypeVo">
        select id as rowId,code,name,is_valid as isValid from ct_srm_research_type
    </select>
</mapper>
