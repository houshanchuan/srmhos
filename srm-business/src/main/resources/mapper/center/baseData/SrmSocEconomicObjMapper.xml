<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediway.hos.srm.business.center.mapper.baseData.SrmSocEconomicObjMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mediway.hos.srm.business.center.model.entity.baseData.SrmSocEconomicObj">
        <id column="id" property="id" />
        <result column="code" property="code" />
        <result column="name" property="name" />
        <result column="is_valid" property="isValid" />
        <result column="is_default" property="isDefault" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, code, name, is_valid, is_default
    </sql>
    <select id="listSocEconomicObj" parameterType="com.mediway.hos.srm.business.center.model.dto.baseData.SocEconomicObjDto" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.SocEconomicObjVo">
        select id as rowId,code,name,is_valid as isValid from ct_srm_soc_economic_obj
    </select>
    <select id="getSocEconomicObj" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.CombVo">
        select code as id,name from ct_srm_soc_economic_obj where is_valid=1
        <if test="socEconomicObjDto.name!=null and socEconomicObjDto.name!=''">
            and name LIKE CONCAT('%', #{socEconomicObjDto.name}, '%')
        </if>
    </select>

</mapper>
