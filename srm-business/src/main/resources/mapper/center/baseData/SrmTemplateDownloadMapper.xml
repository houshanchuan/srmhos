<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediway.hos.srm.business.center.mapper.baseData.SrmTemplateDownloadMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mediway.hos.srm.business.center.model.entity.baseData.SrmTemplateDownload">
        <id column="id" property="id" />
        <result column="year" property="year" />
        <result column="sys_no" property="sysNo" />
        <result column="title" property="title" />
        <result column="temp_type" property="tempType" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, year, sys_no, title, temp_type
    </sql>
    <select id="listTemplateDownload" parameterType="com.mediway.hos.srm.business.center.model.dto.baseData.TemplateDownloadDto" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.TemplateDownloadVo">
        select cstd.id as rowId,cstd.year ,cstd.sys_no as sysNo, cssm.name as sysName,cstd.title,cstd.temp_type as tempType
        from cf_srm_template_download cstd
                 left join ct_srm_system_module cssm on cstd.sys_no =cssm.code
    </select>
    <select id="getDetailTemplateDownload" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.TemplateDownloadVo">
        select id,`year`,sys_no as sysNo,title,temp_type as tempType from cf_srm_template_download where id=#{RowId}
    </select>

</mapper>
