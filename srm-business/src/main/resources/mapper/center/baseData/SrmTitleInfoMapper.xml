<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediway.hos.srm.business.center.mapper.baseData.SrmTitleInfoMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mediway.hos.srm.business.center.model.entity.baseData.SrmTitleInfo">
        <id column="id" property="id" />
        <result column="code" property="code" />
        <result column="name" property="name" />
        <result column="is_valid" property="isValid" />
        <result column="title_level" property="titleLevel" />
        <result column="title_type" property="titleType" />
        <result column="stat_id" property="statId" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, code, name, is_valid, title_level, title_type, stat_id
    </sql>
    <select id="getUserTitle" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.CombVo">
        select code as id,name from ct_srm_title_info where is_valid=1
        <if test="titleInfoDto.name!=null and titleInfoDto.name!=''">
            and name LIKE CONCAT('%', #{titleInfoDto.name}, '%')
        </if>

    </select>
    <select id="listTitleInfo" parameterType="com.mediway.hos.srm.business.center.model.dto.baseData.TitleInfoDto" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.TitleInfoVo">
        select id as rowId,code,name,is_valid as isValid from ct_srm_title_info
    </select>
</mapper>
