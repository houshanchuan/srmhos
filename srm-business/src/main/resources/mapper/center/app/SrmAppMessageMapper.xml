<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediway.hos.srm.business.center.mapper.app.SrmAppMessageMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mediway.hos.srm.business.center.model.entity.app.SrmAppMessage">
        <id column="id" property="id" />
        <result column="sys_no" property="sysNo" />
        <result column="type" property="type" />
        <result column="rec_id" property="recId" />
        <result column="title" property="title" />
        <result column="content" property="content" />
        <result column="note" property="note" />
        <result column="create_date" property="createDate" />
        <result column="user_list" property="userList" />
        <result column="data_status" property="dataStatus" />
        <result column="audit_user_id" property="auditUserId" />
        <result column="audit_date" property="auditDate" />
        <result column="check_status" property="checkStatus" />
        <result column="audit_advice" property="auditAdvice" />
        <result column="step_no" property="stepNo" />
        <result column="hospital_id" property="hospitalId" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, sys_no, type, rec_id, title, content, note, create_date, user_list, data_status, audit_user_id, audit_date, check_status, audit_advice, step_no, hospital_id
    </sql>
    <update id="updateMessage" >
        update srm_app_message set is_delete=1 where sys_no=#{sysNo} and rec_id=#{recId}
    </update>
    <select id="listAppMessage" resultType="com.mediway.hos.srm.business.center.model.vo.app.AppMessageVo">
       select id as rowId,sys_no as sysNo, type, rec_id as recId, title, content, note, create_date as createDate,
        data_status as dataStatus, audit_date as auditDate, check_status as checkStatus, audit_advice as auditAdvice,
        step_no as stepNo from srm_app_message where
        user_list LIKE CONCAT('%', #{appMessageDto.userId}, '%')
        <if test="appMessageDto.dataStatus!=null">
            and data_status = #{appMessageDto.dataStatus}
        </if>
    </select>
</mapper>
