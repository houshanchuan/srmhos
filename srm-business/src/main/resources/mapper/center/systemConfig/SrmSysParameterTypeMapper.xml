<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediway.hos.srm.business.center.mapper.systemConfig.SrmSysParameterTypeMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mediway.hos.srm.business.center.model.entity.systemConfig.SrmSysParameterType">
        <id column="id" property="id" />
        <result column="code" property="code" />
        <result column="name" property="name" />
        <result column="remark" property="remark" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, code, name, remark
    </sql>
    <select id="listSysParameterType" parameterType="com.mediway.hos.srm.business.center.model.dto.systemConfig.SysParameterTypeDto" resultType="com.mediway.hos.srm.business.center.model.vo.systemConfig.SysParameterTypeVo">
        select id as rowId,code,name,remark from cf_srm_sys_parameter_type
    </select>
</mapper>
