<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediway.hos.srm.business.center.mapper.systemConfig.SrmSystemModuleMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mediway.hos.srm.business.center.model.entity.systemConfig.SrmSystemModule">
        <id column="id" property="id" />
        <result column="code" property="code" />
        <result column="name" property="name" />
        <result column="en_name" property="enName" />
        <result column="is_valid" property="isValid" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, code, name, en_name, is_valid
    </sql>
    <select id="getSystemModule" resultType="com.mediway.hos.srm.business.center.model.vo.baseData.CombVo">
        select code as id,name from ct_srm_system_module where is_valid=1
    </select>

    <select id="getSystemModuleByCode" resultType="Long">
        select id from ct_srm_system_module where code=#{code}
    </select>
    <select id="listSystemModule" parameterType="com.mediway.hos.srm.business.center.model.dto.systemConfig.SystemModuleDto" resultType="com.mediway.hos.srm.business.center.model.vo.systemConfig.SystemModuleVo">
        select  id as rowId,code ,name , is_valid as isValid ,en_name as enName   from  ct_srm_system_module
    </select>
</mapper>
