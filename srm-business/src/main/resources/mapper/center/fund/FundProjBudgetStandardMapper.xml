<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediway.hos.srm.business.center.mapper.fund.FundProjBudgetStandardMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mediway.hos.srm.business.center.model.entity.fund.FundProjBudgetStandard">
        <id column="id" property="id" />
        <result column="code" property="code" />
        <result column="name" property="name" />
        <result column="is_valid" property="isValid" />
        <result column="proj_type" property="projType" />
        <result column="start_year" property="startYear" />
        <result column="end_year" property="endYear" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, code, name, is_valid, proj_type, start_year, end_year
    </sql>


    <select id="listFundProjBudgetStandard" parameterType="com.mediway.hos.srm.business.center.model.dto.fund.FundProjBudgetStandardDto" resultType="com.mediway.hos.srm.business.center.model.vo.fund.FundProjBudgetStandardVo">
        select  cfpbs.id as rowId,cfpbs.code ,cfpbs.name ,cfpbs.is_valid as isValid,cfpbs.proj_type as projType,cspt.name as projTypeName
        ,start_year as startYear ,end_year as endYear
        from  ct_fund_proj_budget_standard cfpbs
        left join ct_srm_proj_type cspt on cfpbs.proj_type =cspt.code
    </select>

</mapper>
