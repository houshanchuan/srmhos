<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediway.hos.srm.business.center.mapper.fund.FundBudgetItemDeptGrantMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mediway.hos.srm.business.center.model.entity.fund.FundBudgetItemDeptGrant">
        <id column="id" property="id" />
        <result column="item_code" property="itemCode" />
        <result column="dept_code" property="deptCode" />
        <result column="hosp_code" property="hospCode" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, item_code, dept_code, hosp_code
    </sql>
    <select id="listFundBudgetItemDeptGrant" parameterType="com.mediway.hos.srm.business.center.model.dto.fund.FundBudgetItemDeptGrantDto" resultType="com.mediway.hos.srm.business.center.model.vo.fund.FundBudgetItemDeptGrantVo">
        select cfbidg.id as rowId,cfbidg.item_code as itemCode,cfbi.name as itemName,cfbidg.dept_code as deptCode,csd.name  as deptName,
        cfbidg.hosp_code as hospCode,csh.name as hospName
        from cf_fund_budget_item_dept_grant cfbidg
        left join ct_fund_budget_item cfbi  on cfbidg.item_code=cfbi.code
        left join ct_srm_dept csd on cfbidg.dept_code =csd.code
        left join ct_srm_hospital csh on cfbidg.hosp_code =csh.code
    </select>
</mapper>
