<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediway.hos.srm.business.center.mapper.paper.SrmPaperReshipMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.mediway.hos.srm.business.center.model.entity.paper.SrmPaperReship">
        <id column="id" property="id" />
        <result column="paper_id" property="paperId" />
        <result column="reship_id" property="reshipId" />
        <result column="reship_type" property="reshipType" />
        <result column="reship_date" property="reshipDate" />
        <result column="create_time" property="createTime" />
        <result column="creator_code" property="creatorCode" />
        <result column="creator_id" property="creatorId" />
        <result column="note" property="note" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, paper_id, reship_name, reship_type, reship_date, create_time, creator_code, creator_id, note
    </sql>

    <delete id="deletePaperReshipByPaper">
        delete from srm_paper_reship where paper_id=#{paperId}
    </delete>
    <select id="listPaperReship" resultType="com.mediway.hos.srm.business.center.model.vo.paper.PaperReshipVo">
        select spr.id as rowId,csrn.code as reshipId,csrn.name as reshipName,
        csrt.code as reshipType,csrt.name as reshipTypeName,
        spr.reship_date as reshipDate,
        spr.note as note
        from srm_paper_reship spr
        left join ct_srm_reship_name csrn on csrn.code=spr.reship_id
        left join ct_srm_reship_type csrt on csrt.code=spr.reship_type
        where paper_id=#{paperId}
    </select>
</mapper>
